<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.webaimanagement.mapper.LibraryBookMapper">
    <!-- 批量插入桌位信息 -->
    <insert id="addBook" parameterType="org.example.webaimanagement.pojo.LibraryBookPhotoParam">
        INSERT INTO book_info(
        book_id,
        book_no,
        book_name,
        book_author,
        <if test="book_photo != null and book_photo != ''">
            book_photo,
        </if>
        book_message,
        book_num,
        book_type
        ) VALUES (
        #{book_id},
        #{book_id},
        #{book_name},
        #{book_author},
        <if test="book_photo != null and book_photo != ''">
            #{book_photo1, jdbcType=BLOB},
        </if>
        #{book_message},
        #{book_num},
        #{book_type}
        )
    </insert>
    <update id="updatebook" parameterType="org.example.webaimanagement.pojo.LibraryBookPhotoParam">
        UPDATE book_info
        <set>
            <if test="book_name != null and book_name != ''">
                book_name = #{book_name},
            </if>
            <if test="book_author != null and book_author != ''">
                book_author = #{book_author},
            </if>
            <if test="book_photo1 != null and book_photo1 != ''">
                book_photo = #{book_photo1},
            </if>
            <if test="book_message != null and book_message != ''">
                book_message = #{book_message},
            </if>
            <if test="book_num != null">
                book_num = #{book_num},
            </if>
            <if test="book_type != null and book_type != ''">
                book_type = #{book_type}
            </if>
        </set>
        WHERE book_id = #{book_id}
    </update>
</mapper>
